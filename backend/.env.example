# Dundo backend — environment variables.
#
# Copy to `backend/.env` (gitignored) and fill in. On the Hugging Face Space,
# set the secrets/variables in Space → Settings → Variables and secrets.
# Every var here is read by the code; nothing is required just to boot the API
# (missing optional keys degrade gracefully — see notes).
#
# Retired in v1 (do NOT set): ACRCLOUD_*, BANDSINTOWN_APP_ID. Both removed.

# ============================================================================
# Runtime serving (deploy-time)
# ============================================================================

# Powers the `/narrative` "why this resonates" layer (GPT-4o-mini).
# WITHOUT it: `/narrative` returns 503 narrative-disabled; `/neighbors` is
# unaffected and cards render without the narrative paragraph.
# Get one at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Optional. Defaults to gpt-4o-mini.
# OPENAI_MODEL_ID=gpt-4o-mini

# Signs the opaque contextToken that `/neighbors` attaches. Generate with:
#   openssl rand -hex 32
# WITHOUT it: context signing is disabled and contextToken is null (dev mode).
CONTEXT_TOKEN_HMAC_KEY=

# Allowed CORS origin = your Vercel production URL. Fill in after the frontend
# deploys. Local dev origin shown.
CORS_ORIGIN=http://localhost:5173

# Retrieval backend: `numpy` (current 145-track seed default) or `faiss`
# (the v1 served path at full catalog scale — exact Flat).
# SIMILARITY_BACKEND=numpy

# Optional. Where the corpus files live. Defaults to
# <repo>/quality-scorer/public/corpus.
# CORPUS_DIR=/data/corpus

# Optional. Uvicorn port (HF Space sets this). Defaults to 8000 locally.
# PORT=8000

# Optional. Pin the MuQ-MuLan model revision so manifest writes stay auditable.
# DUNDO_CLAP_REVISION=

# Optional. Hugging Face cache dir (set on the Space so weights persist).
# HF_HOME=/data/.hf_cache

# ============================================================================
# Enrichment (Phase 1/2 — building the artist catalog, not runtime serving)
# Used by: python -m backend.scripts.enrich_spike
# ============================================================================

# Jamendo API client_id — the ONE API key needed to measure enrichment coverage
# on the (Jamendo) seed catalog. Provides artist location (ISO city/country) +
# website/share links. WITHOUT it: the Jamendo enricher returns empty.
# Register a free app at: https://developer.jamendo.com
JAMENDO_CLIENT_ID=

# Path to the extracted FMA metadata dump directory (CSV files). A ~342 MB
# download (https://github.com/mdeff/fma → fma_metadata.zip), NOT a key.
# Only relevant once FMA tracks are ingested (Phase 2). WITHOUT it: FMA
# enricher returns empty.
# FMA_METADATA_DIR=/path/to/fma_metadata

# Path to a MusicBrainz artist dump (JSON). Optional supplement for richer
# links/locations + the Spotify confidence gate. NOT a key. WITHOUT it: the
# MusicBrainz enricher returns empty.
# MUSICBRAINZ_ARTIST_DUMP=/path/to/mb_artists.json

# Optional. On-disk cache dir for enrichment API responses (throttle-friendly).
# Defaults to .cache/dundo-enrich.
# DUNDO_ENRICH_CACHE=.cache/dundo-enrich

# ============================================================================
# Observability (optional)
# ============================================================================

# When SENTRY_DSN is unset, Sentry init is skipped entirely (no overhead).
# SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1
